{
  "name": "@nanotrace/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for sending traces, logs, metrics, and spans to Nanotrace.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suhjohn/nanotrace.git",
    "directory": "packages/sdk-js"
  },
  "bugs": {
    "url": "https://github.com/suhjohn/nanotrace/issues"
  },
  "homepage": "https://github.com/suhjohn/nanotrace/tree/main/packages/sdk-js#readme",
  "keywords": [
    "nanotrace",
    "observability",
    "tracing",
    "metrics",
    "logs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3"
  }
}
