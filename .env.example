# Nanotrace deploy environment template.
#
# Deploy commands read only the process environment. This file is a checklist,
# not an automatic input. Export these variables with your shell, 1Password,
# Infisical, Vault, direnv, or another secret manager before deploy commands.

# ---------------------------------------------------------------------------
# Required deployment identity
# ---------------------------------------------------------------------------

AWS_REGION=us-west-2
NANOTRACE_DOMAIN_NAME=nanotrace.example.com

# Optional but recommended guardrail.
# NANOTRACE_AWS_ACCOUNT_ID=123456789012

# Choose one AWS auth method.
# AWS_PROFILE=nanotrace-prod
# AWS_ACCESS_KEY_ID=change-me
# AWS_SECRET_ACCESS_KEY=change-me
# AWS_SESSION_TOKEN=change-me

# ---------------------------------------------------------------------------
# DNS and email
# ---------------------------------------------------------------------------

# DNS is manual. The stack outputs the records to create after deploy.

# Defaults to login@mail.${NANOTRACE_DOMAIN_NAME}.
# NANOTRACE_EMAIL_FROM=login@mail.nanotrace.example.com

# Optional Google login. The redirect URI is derived from NANOTRACE_PUBLIC_BASE_URL,
# which defaults to https://api.${NANOTRACE_DOMAIN_NAME}.
# NANOTRACE_GOOGLE_OAUTH_CLIENT_ID=change-me
# NANOTRACE_GOOGLE_OAUTH_CLIENT_SECRET=change-me
# Set only if the OAuth client needs an explicit callback override.
# NANOTRACE_GOOGLE_OAUTH_REDIRECT_URI=https://api.nanotrace.example.com/auth/google/callback

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------

CLICKHOUSE_URL=https://your-service.region.provider.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DATABASE=observatory

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------

# For WarpStream, use the virtual cluster bootstrap_url from the console. Pulumi
# deploys a VPC-local bootstrap load balancer for Nanotrace runtime traffic.
NANOTRACE_KAFKA_BROKERS=api-xxxxxxxx.kafka.discoveryv2.prod-x.us-west-2.warpstream.com:9092

# Optional runtime Kafka client overrides for the Nanotrace app containers.
# BYOC agents expose plaintext Kafka unless you configure agent TLS/SASL.
# NANOTRACE_APP_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# NANOTRACE_APP_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# NANOTRACE_APP_KAFKA_SASL_USERNAME=change-me
# NANOTRACE_APP_KAFKA_SASL_PASSWORD=change-me

# Required for WarpStream BYOC. Pulumi deploys dedicated warpstream-agent EC2
# instances and a dedicated S3 bucket for the agents. If the Kafka bootstrap URL
# includes group$NAME, the agent group is inferred from the URL unless overridden.
NANOTRACE_WARPSTREAM_VIRTUAL_CLUSTER_ID=vci_change_me
NANOTRACE_WARPSTREAM_AGENT_KEY=change-me
NANOTRACE_WARPSTREAM_TABLEFLOW_VIRTUAL_CLUSTER_ID=vci_change_me
NANOTRACE_WARPSTREAM_TABLEFLOW_AGENT_KEY=change-me
# NANOTRACE_WARPSTREAM_REGION=us-west-2
# NANOTRACE_WARPSTREAM_TABLEFLOW_REGION=us-west-2
# NANOTRACE_WARPSTREAM_AGENT_GROUP=default

# Defaults if omitted:
# NANOTRACE_KAFKA_INGEST_TOPIC=events.ingest.v1
# NANOTRACE_KAFKA_NORMALIZED_TOPIC=events.normalized.v1
# NANOTRACE_KAFKA_TABLEFLOW_TOPIC=events.tableflow.batches.v1
# NANOTRACE_KAFKA_ICEBERG_TOPIC=events.iceberg.rows.v1
# NANOTRACE_KAFKA_INVALID_TOPIC=events.invalid.v1

# ---------------------------------------------------------------------------
# WarpStream Tableflow
# ---------------------------------------------------------------------------

# Configure WarpStream Tableflow to read NANOTRACE_KAFKA_ICEBERG_TOPIC and write
# the managed Iceberg table into the BYOC object-storage bucket. Nanotrace app
# containers do not write Iceberg files or talk to a writable catalog.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------

# Required PlanetScale Postgres control database.
# Use the PlanetScale private host. Prefer PgBouncer port 6432 for app traffic.
DATABASE_URL=postgres://nanotrace:change-me@private-host.psdb.cloud:6432/nanotrace?sslmode=verify-full
PLANETSCALE_PRIVATELINK_SERVICE_NAME=com.amazonaws.vpce.us-west-2.vpce-svc-...

# ---------------------------------------------------------------------------
# Existing-stack compatibility
# ---------------------------------------------------------------------------

# Set only when preserving an existing stack that used a non-default object
# prefix. New stacks can omit this.
# S3_PREFIX=events

# ---------------------------------------------------------------------------
# Post-deploy verification
# ---------------------------------------------------------------------------

# Required by npm run e2e:pulumi, not by deploy.
# NANOTRACE_E2E_API_KEY=ntak_change_me
