SECRET_KEY=change-me

OBJECT_STORE_PROVIDER=s3_compatible
NANOTRACE_OBJECT_PREFIX=events
NANOTRACE_ENV=dev
NANOTRACE_DEPLOYMENT_ID=dev
# Resource base defaults to nanotrace-${NANOTRACE_DEPLOYMENT_ID}.

# Cloudflare deploy API token.
CLOUDFLARE_API_TOKEN=change-me
CLOUDFLARE_ACCOUNT_ID=change-me

# Cloudflare object storage. NANOTRACE_S3_BUCKET defaults to
# nanotrace-${NANOTRACE_DEPLOYMENT_ID}-events-${CLOUDFLARE_ACCOUNT_ID}.
# NANOTRACE_S3_BUCKET=
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_ACCOUNT_ID=
S3_PREFIX=events
R2_JURISDICTION=default
R2_BUCKET_LOCATION=wnam
R2_BUCKET_STORAGE_CLASS=Standard
# AWS S3. Use OBJECT_STORE_PROVIDER=aws for AWS deployments.
AWS_REGION=us-east-1
# NANOTRACE_S3_BUCKET defaults to nanotrace-${NANOTRACE_DEPLOYMENT_ID}-events-<aws-account-id>-<region>.
# NANOTRACE_ECR_REPOSITORY defaults to nanotrace-${NANOTRACE_DEPLOYMENT_ID}-server.

# GCP. Pulumi creates Cloud Storage, Artifact Registry, Cloud Run, and HMAC credentials.
GCP_PROJECT=change-me
GCP_REGION=us-central1
# NANOTRACE_GCS_BUCKET defaults to nanotrace-${NANOTRACE_DEPLOYMENT_ID}-events-<project>-<region>.

# Azure. Pulumi creates Blob Storage, ACR, Container Apps, and SAS credentials.
AZURE_LOCATION=eastus
# NANOTRACE_AZURE_RESOURCE_GROUP defaults to nanotrace-${NANOTRACE_DEPLOYMENT_ID}.

CLICKHOUSE_URL=https://your-service.region.provider.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_DATABASE=observatory

NANOTRACE_INGEST_URL=https://your-worker-host.example.com
NANOTRACE_URL=https://your-worker-host.example.com
NANOTRACE_KEY=change-me
NANOTRACE_CLIENT_BIND=127.0.0.1:4319
NANOTRACE_CLIENT_BATCH_MAX_EVENTS=100
NANOTRACE_CLIENT_BATCH_MAX_BYTES=1048576
NANOTRACE_CLIENT_FLUSH_MS=25
NANOTRACE_CLIENT_QUEUE_CAPACITY=10000
NANOTRACE_CLIENT_HTTP_TIMEOUT_MS=5000
NANOTRACE_CLIENT_RETRY_ATTEMPTS=3
NANOTRACE_SERVICE=my-service
NANOTRACE_VERSION=local

MAX_REQUEST_BYTES=209715200
MAX_EVENT_BYTES=209715200
MAX_ATTRIBUTES_BYTES=786432
NANOTRACE_DATA_DIR=/data/events
NANOTRACE_PART_MAX_BYTES=67108864
NANOTRACE_PART_MAX_AGE_SECS=1
UPLOAD_POLL_INTERVAL_MS=500
PROCESSOR_POLL_INTERVAL_SECS=30
NANOTRACE_DONE_RETENTION_MINS=60
NANOTRACE_DONE_CLEANUP_INTERVAL_SECS=60
NANOTRACE_E2E_WAIT_MS=180000
NANOTRACE_E2E_POLL_MS=5000
NANOTRACE_WRITER_INSTANCE_TYPE=t4g.medium
NANOTRACE_AWS_READY_TIMEOUT_MS=300000
# Defaults to .nanotrace/deployments/nanotrace-${NANOTRACE_DEPLOYMENT_ID}/cloudflare-partitions.json.
# PARTITION_STATE_FILE=
