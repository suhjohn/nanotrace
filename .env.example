# Nanotrace environment template.
# Deployment scripts do not read this file directly. Export these variables
# into the process environment with your shell, 1Password, Infisical, Vault,
# direnv, or another secret manager before running deploy commands.

# ---------------------------------------------------------------------------
# Deployment identity
# ---------------------------------------------------------------------------

# Defaults to the Pulumi stack when omitted.
# NANOTRACE_NAME=nanotrace-prod
# NANOTRACE_AWS_ACCOUNT_ID=123456789012

# Required by deploy/pulumi/nanotrace. The app defaults to:
#   app: https://${NANOTRACE_DOMAIN_NAME}
#   api: https://api.${NANOTRACE_DOMAIN_NAME}
#   email sender: login@mail.${NANOTRACE_DOMAIN_NAME}
NANOTRACE_DOMAIN_NAME=nanotrace.example.com

# Optional domain overrides.
# NANOTRACE_API_DOMAIN_NAME=api.nanotrace.example.com
# NANOTRACE_APP_BASE_URL=https://nanotrace.example.com
# NANOTRACE_API_BASE_URL=https://api.nanotrace.example.com
# NANOTRACE_PUBLIC_BASE_URL=https://api.nanotrace.example.com
# VITE_NANOTRACE_URL=https://api.nanotrace.example.com
# NANOTRACE_CORS_ALLOWED_ORIGINS=https://nanotrace.example.com,http://localhost:41233,http://127.0.0.1:41233,http://localhost:41234,http://127.0.0.1:41234,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# ---------------------------------------------------------------------------
# AWS and DNS
# ---------------------------------------------------------------------------

AWS_REGION=us-east-1
# AWS_PROFILE=nanotrace-prod
# AWS_ACCESS_KEY_ID=change-me
# AWS_SECRET_ACCESS_KEY=change-me
# AWS_SESSION_TOKEN=change-me

# Cloudflare is selected automatically when CLOUDFLARE_API_TOKEN is set.
# Without Cloudflare, the stack uses Route53.
# CLOUDFLARE_API_TOKEN=change-me
# CLOUDFLARE_ZONE_ID=change-me
# NANOTRACE_HOSTED_ZONE_NAME=nanotrace.example.com
# NANOTRACE_HOSTED_ZONE_ID=Z1234567890

# DNS provider is "cloudflare", "route53", or "external". External DNS exports
# manual DNS records instead of creating provider-specific records.
# NANOTRACE_DNS_PROVIDER=external

# TLS is "edge-flexible" when an external edge/proxy terminates HTTPS, otherwise "alb".
# NANOTRACE_EDGE_TLS_MODE=edge-flexible
# NANOTRACE_MANAGE_LOGIN_EMAIL_DNS=true

# ---------------------------------------------------------------------------
# Auth, login, and email
# ---------------------------------------------------------------------------

NANOTRACE_EMAIL_FROM=login@mail.nanotrace.example.com
NANOTRACE_ALLOWED_EMAILS=
NANOTRACE_ADMIN_EMAILS=admin@example.com

# NANOTRACE_SESSION_SECURE=true
# Use None only when a browser must send session cookies cross-site, such as
# localhost UI -> https://api.nanotrace.example.com. SameSite=None requires Secure.
# NANOTRACE_SESSION_SAME_SITE=Lax
# NANOTRACE_SESSION_COOKIE=nanotrace_session
# NANOTRACE_SESSION_TTL_SECS=604800
# NANOTRACE_MAGIC_LINK_TTL_SECS=600

# ---------------------------------------------------------------------------
# Postgres control database
# ---------------------------------------------------------------------------

# managed: Pulumi creates an encrypted private RDS Postgres instance.
# external: provide NANOTRACE_POSTGRES_URL.
NANOTRACE_POSTGRES_MODE=managed
# NANOTRACE_POSTGRES_URL=postgres://nanotrace:change-me@postgres.example.com:5432/nanotrace

# Optional external Postgres private connectivity. For PlanetScale PrivateLink,
# set mode=external, private connect=aws-privatelink, and paste the service name
# supplied by PlanetScale.
# NANOTRACE_POSTGRES_PRIVATE_CONNECT=none
# NANOTRACE_POSTGRES_PRIVATELINK_SERVICE_NAME=com.amazonaws.vpce.us-east-1.vpce-svc-...

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------

# Nanotrace expects an existing ClickHouse Cloud service. Pulumi applies the
# schema to this database but does not create or resize the service.
CLICKHOUSE_URL=https://your-service.region.provider.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me

# Nanotrace database/tables inside the assigned ClickHouse service.
CLICKHOUSE_DATABASE=observatory

# Optional table/limit overrides.
# CLICKHOUSE_TABLE=events
# CLICKHOUSE_EVENT_TEXT_INDEX_TABLE=event_text_index
# CLICKHOUSE_EVENT_SEARCH_TERMS_TABLE=event_search_terms
# CLICKHOUSE_EVENT_KV_INDEX_TABLE=event_kv_index
# CLICKHOUSE_FIELD_INDEX_TABLE=field_index
# CLICKHOUSE_EVENT_MEASURES_TABLE=event_measures
# CLICKHOUSE_ALERT_EVENTS_TABLE=alert_events
# CLICKHOUSE_ALERT_NOTIFICATIONS_TABLE=alert_notifications
# CLICKHOUSE_ENTITY_STATE_UPDATES_TABLE=entity_state_updates
# CLICKHOUSE_ENTITY_STATE_CURRENT_TABLE=entity_state_current
# CLICKHOUSE_MAX_RESULT_ROWS=100000
# CLICKHOUSE_MAX_EXECUTION_SECS=30
# CLICKHOUSE_MAX_BYTES_TO_READ=1000000000000
# CLICKHOUSE_SCHEMA_PATH=deploy/clickhouse/schema.sql

# ---------------------------------------------------------------------------
# Deployment artifact storage
# ---------------------------------------------------------------------------

# Prefix for Pulumi-managed debug artifacts. This is not an ingest path.
S3_PREFIX=ops
# NANOTRACE_OBJECT_PREFIX=ops

# NANOTRACE_PROVISIONER_CLICKHOUSE_DATABASE=org_manual_override

# ---------------------------------------------------------------------------
# Runtime tuning
# ---------------------------------------------------------------------------

# Pulumi normally injects these into EC2 containers. Override only when running
# services directly or tuning the deployed stack.
# PORT=18473
# NANOTRACE_UI_DIR=/usr/local/share/nanotrace/ui
# MAX_REQUEST_BYTES=209715200
# MAX_EVENT_BYTES=209715200
# MAX_ATTRIBUTES_BYTES=786432
# NANOTRACE_KAFKA_BROKERS=...
# NANOTRACE_KAFKA_INGEST_TOPIC=events.ingest.v1
# NANOTRACE_KAFKA_NORMALIZED_TOPIC=events.normalized.v1
# NANOTRACE_KAFKA_INVALID_TOPIC=events.invalid.v1
# NANOTRACE_KAFKA_CLIENT_ID=nanotrace-server
# For WarpStream or any SASL/TLS Kafka endpoint.
# NANOTRACE_KAFKA_SECURITY_PROTOCOL=SASL_SSL
# NANOTRACE_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# NANOTRACE_KAFKA_SASL_USERNAME=change-me
# NANOTRACE_KAFKA_SASL_PASSWORD=change-me
# NANOTRACE_NORMALIZER_GROUP_ID=nanotrace-normalizer
# NANOTRACE_NORMALIZER_CLIENT_ID=nanotrace-normalizer
# NANOTRACE_ALERTS_GROUP_ID=nanotrace-alerts
# NANOTRACE_ALERTS_CLIENT_ID=nanotrace-alerts
# NANOTRACE_ALERTS_DEFINITION_REFRESH_SECS=10
# NANOTRACE_ALERTS_MAX_DEDUPE_KEYS=100000
# NANOTRACE_ALERTS_NOTIFIER=false
# NANOTRACE_ALERTS_NOTIFY_POLL_SECS=5
# NANOTRACE_ALERTS_NOTIFY_BATCH_SIZE=100
# NANOTRACE_LAKEHOUSE_ENABLED=true
# Local fallback directory. Deployed production should use Iceberg REST plus object storage.
# NANOTRACE_LAKEHOUSE_WAREHOUSE_DIR=/var/lib/nanotrace/lakehouse
# NANOTRACE_ICEBERG_REST_URI=https://iceberg-catalog.example.com
# NANOTRACE_ICEBERG_WAREHOUSE=s3://<pulumi-storage-bucket>/iceberg
# NANOTRACE_ICEBERG_WAREHOUSE_PREFIX=iceberg
# NANOTRACE_ICEBERG_CATALOG_NAME=nanotrace
# NANOTRACE_ICEBERG_REST_PREFIX=
# NANOTRACE_ICEBERG_TARGET_FILE_SIZE_BYTES=536870912
# NANOTRACE_ICEBERG_MIN_SNAPSHOTS_TO_KEEP=10000
# NANOTRACE_ICEBERG_MAX_SNAPSHOT_AGE_MS=604800000
# NANOTRACE_ICEBERG_METADATA_PREVIOUS_VERSIONS_MAX=100
# NANOTRACE_REBUILD_TRUNCATE=false
# NANOTRACE_REBUILD_RAW=true
# NANOTRACE_REBUILD_DERIVED=true
# NANOTRACE_REBUILD_COMMIT_SOURCE=local
# NANOTRACE_MATERIALIZE_INCREMENTAL=false
# NANOTRACE_MATERIALIZE_LOOP=false
# NANOTRACE_MATERIALIZE_POLL_SECS=5
# NANOTRACE_MATERIALIZATION_QUEUE_EXECUTOR=false
# NANOTRACE_MATERIALIZATION_QUEUE_MAX_CHUNKS=10
# NANOTRACE_MATERIALIZATION_QUEUE_LEASE_SECS=300
# NANOTRACE_MATERIALIZATION_QUEUE_WORKER_ID=lakehouse-rebuild
# NANOTRACE_REBUILD_ALLOW_NON_EMPTY=false
# NANOTRACE_REBUILD_FROM_SEQUENCE=0
# NANOTRACE_REBUILD_S3_MAX_FILE_BYTES=1073741824
# NANOTRACE_LAKEHOUSE_MAINTENANCE=false
# NANOTRACE_LAKEHOUSE_MAINTENANCE_SMALL_FILE_BYTES=134217728
# NANOTRACE_LAKEHOUSE_NATIVE_COMPACTION=false
# NANOTRACE_LAKEHOUSE_NATIVE_COMPACTION_MIN_INPUT_FILES=2
# NANOTRACE_LAKEHOUSE_NATIVE_COMPACTION_TARGET_FILE_SIZE_BYTES=536870912
# NANOTRACE_ICEBERG_MAINTENANCE_CMD=
# NANOTRACE_LAKEHOUSE_QUERY=false
# NANOTRACE_LAKEHOUSE_QUERY_TENANT_ID=
# NANOTRACE_LAKEHOUSE_QUERY_FROM=
# NANOTRACE_LAKEHOUSE_QUERY_TO=
# NANOTRACE_LAKEHOUSE_QUERY_EVENT_TYPE=
# NANOTRACE_LAKEHOUSE_QUERY_TEXT=
# NANOTRACE_LAKEHOUSE_QUERY_REGEX=
# NANOTRACE_LAKEHOUSE_QUERY_SQL=
# Optional semicolon-separated external Parquet tables for SQL joins:
# table=/abs/file.parquet,s3://bucket/part.parquet;other=/abs/other.parquet
# NANOTRACE_LAKEHOUSE_QUERY_TABLES=
# NANOTRACE_LAKEHOUSE_QUERY_LIMIT=1000

# Pulumi image tagging.
# NANOTRACE_IMAGE_BUILD_ID=latest
# NANOTRACE_BUILD_UI=true

# ---------------------------------------------------------------------------
# Local UI and sidecar/client development
# ---------------------------------------------------------------------------

NANOTRACE_API_KEY=ntak_change_me
NANOTRACE_URL=https://api.nanotrace.example.com
NANOTRACE_INGEST_URL=https://api.nanotrace.example.com
# NANOTRACE_KEY=ntak_change_me
# NANOTRACE_UI_PORT=41233
# TRACER_URL=http://localhost:18473
# TRACER_UI_PORT=41233

# Frontend local-dev overrides.
# VITE_NANOTRACE_API_KEY=ntak_change_me
# VITE_NANOTRACE_TABLE=events
# VITE_NANOTRACE_FIELD_INDEX_TABLE=field_index

# Sidecar batching defaults.
# NANOTRACE_CLIENT_BIND=127.0.0.1:4319
# NANOTRACE_CLIENT_HTTP_BIND=127.0.0.1:4320
# NANOTRACE_CLIENT_BATCH_MAX_EVENTS=100
# NANOTRACE_CLIENT_BATCH_MAX_BYTES=1048576
# NANOTRACE_CLIENT_FLUSH_MS=25
# NANOTRACE_CLIENT_QUEUE_CAPACITY=10000
# NANOTRACE_CLIENT_SPOOL_DIR=/var/lib/nanotrace-sidecar/spool
# NANOTRACE_CLIENT_SPOOL_POLL_MS=1000
# NANOTRACE_CLIENT_UDP_MAX_BYTES=65507
# NANOTRACE_CLIENT_HTTP_MAX_BYTES=1048576
# NANOTRACE_CLIENT_HTTP_TIMEOUT_MS=5000
# NANOTRACE_CLIENT_RETRY_ATTEMPTS=3
# NANOTRACE_CLIENT_RETRY_BASE_MS=100
# NANOTRACE_SERVICE=my-service
# NANOTRACE_VERSION=local

# ---------------------------------------------------------------------------
# Test, load, and operator scripts
# ---------------------------------------------------------------------------

# Pulumi wrapper scripts default this to an empty passphrase.
# PULUMI_CONFIG_PASSPHRASE=

# E2E script.
# NANOTRACE_E2E_WAIT_MS=180000
# NANOTRACE_E2E_POLL_MS=5000
# NANOTRACE_E2E_CLICKHOUSE_WAIT_MS=300000
# NANOTRACE_E2E_EVENT_ID=e2e-local

# Load test.
# NANOTRACE_LOADTEST_RUN_ID=loadtest-local
# NANOTRACE_LOADTEST_PROFILE=default
# NANOTRACE_LOADTEST_BATCH_SIZES=1,10,100
# NANOTRACE_LOADTEST_STEP_SECONDS=30
# NANOTRACE_LOADTEST_COOLDOWN_MS=2000
# NANOTRACE_LOADTEST_START_RPS=1
# NANOTRACE_LOADTEST_MAX_RPS=2000
# NANOTRACE_LOADTEST_BINARY_ROUNDS=6
# NANOTRACE_LOADTEST_MAX_ERROR_RATE=0.01
# NANOTRACE_LOADTEST_MAX_P95_MS=2000
# NANOTRACE_LOADTEST_MAX_IN_FLIGHT=2000
# NANOTRACE_LOADTEST_LOG_RATIO=0.10
# NANOTRACE_LOADTEST_CLICKHOUSE_WAIT_MS=300000
# NANOTRACE_LOADTEST_CLICKHOUSE_POLL_MS=5000
# NANOTRACE_LOADTEST_GENERATORS=4

# Backfill and benchmark helper scripts.
# NANOTRACE_BACKFILL_INPUT=fixtures/generated/llm_logs_7d_10m.ndjson
# NANOTRACE_BACKFILL_COUNT=
# NANOTRACE_BACKFILL_SKIP=0
# NANOTRACE_BACKFILL_BATCH_SIZE=500
# NANOTRACE_BACKFILL_CONCURRENCY=8
# NANOTRACE_BACKFILL_PROGRESS_EVERY=25000
# NANOTRACE_BACKFILL_RETRIES=5
# NANOTRACE_FACET_BACKFILL_BATCH_SIZE=50000
# NANOTRACE_FACET_BACKFILL_SOURCE=clickhouse
# NANOTRACE_FACET_BACKFILL_CONCURRENCY=16
# NANOTRACE_FACET_BACKFILL_WHERE=
# NANOTRACE_FACET_BACKFILL_LIMIT=
# NANOTRACE_BENCH_DATABASE=nanotrace_bench_10m
# ASG roll/scale helper scripts.
# NANOTRACE_NODE24_BIN=$HOME/.nvm/versions/node/v24.12.0/bin
# NANOTRACE_ROLL_WAIT_MS=1200000
# NANOTRACE_ROLL_POLL_MS=15000
# NANOTRACE_SCALE_WAIT_MS=900000
# NANOTRACE_SCALE_POLL_MS=10000
# NANOTRACE_ASG_NAME=nanotrace-prod-asg
# NANOTRACE_AWS_READY_TIMEOUT_MS=300000

# Defaults to .nanotrace/deployments/nanotrace-${Pulumi stack name}/cloudflare-partitions.json.
# PARTITION_STATE_FILE=
