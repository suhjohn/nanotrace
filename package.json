{
  "name": "nanotrace",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/ui",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build",
    "bootstrap:maximal-pack:apply": "node scripts/bootstrap-maximal-events-pack.mjs --apply",
    "bootstrap:maximal-pack:json": "node scripts/bootstrap-maximal-events-pack.mjs --json",
    "bootstrap:maximal-pack:summary": "node scripts/bootstrap-maximal-events-pack.mjs --summary",
    "deploy:preview": "node scripts/pulumi-nanotrace.mjs preview",
    "deploy:up": "node scripts/pulumi-nanotrace.mjs up",
    "deploy:destroy": "node scripts/pulumi-nanotrace.mjs destroy",
    "deploy:roll": "node scripts/deploy-roll-pulumi.mjs",
    "dev:up": "docker compose -f docker-compose.dev.yml up --build",
    "dev:up:detached": "docker compose -f docker-compose.dev.yml up -d --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:seed-auth": "node scripts/seed-dev-auth.mjs",
    "dev:schema:reset": "CLICKHOUSE_RESET_DATABASE=true docker compose -f docker-compose.dev.yml run --rm clickhouse-schema",
    "lakehouse:rebuild:local": "docker compose -f docker-compose.dev.yml run --rm --no-deps server /usr/local/bin/nanotrace-lakehouse-rebuild",
    "lakehouse:materializer:local": "NANOTRACE_MATERIALIZE_LOOP=true docker compose -f docker-compose.dev.yml run -d --name nanotrace-dev-materializer --no-deps server /usr/local/bin/nanotrace-lakehouse-rebuild",
    "loadtest:local": "NANOTRACE_INGEST_URL=${NANOTRACE_INGEST_URL:-http://localhost:18473} NANOTRACE_API_KEY=${NANOTRACE_API_KEY:-ntak_dev} CLICKHOUSE_URL=${CLICKHOUSE_URL:-http://localhost:18123} CLICKHOUSE_USER=${CLICKHOUSE_USER:-default} CLICKHOUSE_PASSWORD=${CLICKHOUSE_PASSWORD:-nanotrace} CLICKHOUSE_DATABASE=${CLICKHOUSE_DATABASE:-observatory} CLICKHOUSE_TABLE=${CLICKHOUSE_TABLE:-events} cargo run --release -p nanotrace-loadtest --",
    "materialization:loadtest": "node scripts/materialization-loadtest.mjs",
    "dev:rewrite:loadtest": "npm run dev:schema:reset && NANOTRACE_LOADTEST_RUN_ID=${NANOTRACE_LOADTEST_RUN_ID:-loadtest-local} NANOTRACE_LOADTEST_TOTAL_EVENTS=${NANOTRACE_LOADTEST_TOTAL_EVENTS:-1000} NANOTRACE_LOADTEST_BATCH_SIZES=${NANOTRACE_LOADTEST_BATCH_SIZES:-100} npm run loadtest:local",
    "integration:kafka": "node tests/integration/kafka-e2e.mjs",
    "e2e:pulumi": "node scripts/e2e-pulumi.mjs",
    "loadtest:pulumi": "cargo run --release -p nanotrace-loadtest --",
    "scale": "node scripts/scale-pulumi-asg.mjs",
    "scale:down": "node scripts/scale-pulumi-asg.mjs 0",
    "scale:up": "node scripts/scale-pulumi-asg.mjs 1",
    "scale:one": "node scripts/scale-pulumi-asg.mjs 1",
    "scale:two": "node scripts/scale-pulumi-asg.mjs 2",
    "typecheck": "npm --workspaces run typecheck"
  },
  "engines": {
    "node": ">=18.16"
  },
  "dependencies": {
    "@pulumi/confluentcloud": "^2.68.0"
  },
  "devDependencies": {
    "@pulumi/aws": "^7.29.0",
    "@pulumi/cloudflare": "^6.15.0",
    "@pulumi/command": "^1.2.1",
    "@pulumi/pulumi": "^3.236.0",
    "@pulumi/random": "^4.19.2",
    "@types/node": "^25.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
